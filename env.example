# .env.example — Discord Bridge Environment Variables
# Used by discord-bridge.js when running locally,
# or set these as environment variables in Railway.
#
# Copy this file and rename it to .env, then fill in your values.

# Your Discord bot token (from discord.com/developers → Bot → Token)
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN

# The Discord channel ID to listen in
DISCORD_CHANNEL_ID=YOUR_DISCORD_CHANNEL_ID

# Port for the local WebSocket server (default: 8081)
# On Railway, set this to whatever port you expose
DISCORD_BRIDGE_WS_PORT=8081
